{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/dashboard_snapshot.schema.json",
  "title": "PM Agentic AI Dashboard Snapshot",
  "description": "Schema for one monthly snapshot that combines benchmark results, capability scores, and realized exposure outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_month",
    "capability_families",
    "benchmark_capability_matrix",
    "task_capability_matrix",
    "models",
    "benchmark_results",
    "capability_scores",
    "task_realized_exposure",
    "occupation_realized_exposure"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "snapshot_month": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "Month label in YYYY-MM format."
    },
    "notes": {
      "type": "string"
    },
    "capability_families": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability_family"
      }
    },
    "benchmark_capability_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/benchmark_capability_row"
      }
    },
    "task_capability_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task_capability_row"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model"
      }
    },
    "benchmark_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/benchmark_result"
      }
    },
    "capability_scores": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability_score"
      }
    },
    "task_realized_exposure": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task_realized_exposure_row"
      }
    },
    "occupation_realized_exposure": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/occupation_realized_exposure_row"
      }
    }
  },
  "$defs": {
    "month_string": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "weight_0_1": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "score_0_100": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "capability_family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_family_id",
        "label",
        "description"
      ],
      "properties": {
        "capability_family_id": {
          "type": "string",
          "enum": [
            "research",
            "synthesis_reporting",
            "planning_orchestration",
            "tool_use",
            "workflow_execution",
            "computer_use",
            "policy_compliance",
            "technical_execution"
          ]
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "benchmark_capability_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_id",
        "benchmark_label",
        "benchmark_variant",
        "dashboard_role",
        "dashboard_weight",
        "research",
        "synthesis_reporting",
        "planning_orchestration",
        "tool_use",
        "workflow_execution",
        "computer_use",
        "policy_compliance",
        "technical_execution",
        "official_source_url",
        "last_verified_date"
      ],
      "properties": {
        "benchmark_id": {
          "type": "string"
        },
        "benchmark_label": {
          "type": "string"
        },
        "benchmark_variant": {
          "type": "string"
        },
        "dashboard_role": {
          "type": "string",
          "enum": [
            "primary",
            "secondary"
          ]
        },
        "dashboard_weight": {
          "$ref": "#/$defs/weight_0_1"
        },
        "research": {
          "$ref": "#/$defs/weight_0_1"
        },
        "synthesis_reporting": {
          "$ref": "#/$defs/weight_0_1"
        },
        "planning_orchestration": {
          "$ref": "#/$defs/weight_0_1"
        },
        "tool_use": {
          "$ref": "#/$defs/weight_0_1"
        },
        "workflow_execution": {
          "$ref": "#/$defs/weight_0_1"
        },
        "computer_use": {
          "$ref": "#/$defs/weight_0_1"
        },
        "policy_compliance": {
          "$ref": "#/$defs/weight_0_1"
        },
        "technical_execution": {
          "$ref": "#/$defs/weight_0_1"
        },
        "official_source_url": {
          "type": "string",
          "format": "uri"
        },
        "last_verified_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "task_capability_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "onet_task_text",
        "benchmark_observability",
        "research",
        "synthesis_reporting",
        "planning_orchestration",
        "tool_use",
        "workflow_execution",
        "computer_use",
        "policy_compliance",
        "technical_execution"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^T\\d{2}$"
        },
        "onet_task_text": {
          "type": "string"
        },
        "benchmark_observability": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "research": {
          "$ref": "#/$defs/weight_0_1"
        },
        "synthesis_reporting": {
          "$ref": "#/$defs/weight_0_1"
        },
        "planning_orchestration": {
          "$ref": "#/$defs/weight_0_1"
        },
        "tool_use": {
          "$ref": "#/$defs/weight_0_1"
        },
        "workflow_execution": {
          "$ref": "#/$defs/weight_0_1"
        },
        "computer_use": {
          "$ref": "#/$defs/weight_0_1"
        },
        "policy_compliance": {
          "$ref": "#/$defs/weight_0_1"
        },
        "technical_execution": {
          "$ref": "#/$defs/weight_0_1"
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_id",
        "display_name",
        "provider"
      ],
      "properties": {
        "model_id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "release_date": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "benchmark_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_month",
        "model_id",
        "benchmark_id",
        "benchmark_variant",
        "comparability_group",
        "metric_name",
        "metric_unit",
        "score_raw",
        "score_normalized_100",
        "score_date",
        "source_url",
        "official_source_url",
        "source_type",
        "result_quality_weight"
      ],
      "properties": {
        "snapshot_month": {
          "$ref": "#/$defs/month_string"
        },
        "model_id": {
          "type": "string"
        },
        "benchmark_id": {
          "type": "string"
        },
        "benchmark_variant": {
          "type": "string"
        },
        "comparability_group": {
          "type": "string"
        },
        "metric_name": {
          "type": "string"
        },
        "metric_unit": {
          "type": "string",
          "enum": [
            "percent_100",
            "proportion_0_1"
          ]
        },
        "score_raw": {
          "type": "number"
        },
        "score_normalized_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "score_date": {
          "type": "string",
          "format": "date"
        },
        "scaffold_type": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "official_source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "official_leaderboard",
            "official_dataset",
            "official_paper",
            "third_party_reproduction",
            "vendor_report",
            "self_reported"
          ]
        },
        "result_quality_weight": {
          "$ref": "#/$defs/weight_0_1"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "capability_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_month",
        "model_id",
        "capability_family_id",
        "capability_score_100",
        "coverage_weight",
        "benchmark_count",
        "contributing_benchmark_ids"
      ],
      "properties": {
        "snapshot_month": {
          "$ref": "#/$defs/month_string"
        },
        "model_id": {
          "type": "string"
        },
        "capability_family_id": {
          "type": "string"
        },
        "capability_score_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "coverage_weight": {
          "$ref": "#/$defs/weight_0_1"
        },
        "benchmark_count": {
          "type": "integer",
          "minimum": 0
        },
        "contributing_benchmark_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "task_realized_exposure_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_month",
        "model_id",
        "task_id",
        "structural_exposure_100",
        "capability_fit_100",
        "realized_exposure_100",
        "oc_100",
        "benchmark_coverage_ratio"
      ],
      "properties": {
        "snapshot_month": {
          "$ref": "#/$defs/month_string"
        },
        "model_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string",
          "pattern": "^T\\d{2}$"
        },
        "structural_exposure_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "capability_fit_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "realized_exposure_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "oc_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "benchmark_coverage_ratio": {
          "$ref": "#/$defs/weight_0_1"
        }
      }
    },
    "occupation_realized_exposure_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_month",
        "model_id",
        "occupation_code",
        "occupation_label",
        "realized_occupation_exposure_100",
        "weighted_dae_100",
        "weighted_se_100",
        "weighted_oc_100",
        "weighted_ic_100",
        "benchmark_coverage_ratio",
        "included_task_count"
      ],
      "properties": {
        "snapshot_month": {
          "$ref": "#/$defs/month_string"
        },
        "model_id": {
          "type": "string"
        },
        "occupation_code": {
          "type": "string"
        },
        "occupation_label": {
          "type": "string"
        },
        "realized_occupation_exposure_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "weighted_dae_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "weighted_se_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "weighted_oc_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "weighted_ic_100": {
          "$ref": "#/$defs/score_0_100"
        },
        "benchmark_coverage_ratio": {
          "$ref": "#/$defs/weight_0_1"
        },
        "included_task_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
