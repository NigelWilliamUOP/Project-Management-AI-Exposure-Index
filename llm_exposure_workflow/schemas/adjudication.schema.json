{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adjudication Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_item_id",
    "review_type",
    "issue_type",
    "decision",
    "revised_fields",
    "replacement_evidence_chunk_ids",
    "confidence",
    "justification"
  ],
  "properties": {
    "review_item_id": {
      "type": "string",
      "minLength": 1
    },
    "review_type": {
      "type": "string",
      "enum": [
        "task_profile",
        "direct_exposure",
        "task_dependency"
      ]
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "low_confidence",
        "contradictory_evidence",
        "missing_evidence",
        "inconsistent_score",
        "duplicate_edge",
        "weak_rationale",
        "human_flag"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "confirm",
        "revise",
        "reject",
        "escalate_for_human"
      ]
    },
    "revised_fields": {
      "type": "object"
    },
    "replacement_evidence_chunk_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    }
  }
}
