{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Pair Dependency",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_task_id",
    "target_task_id",
    "relation_type",
    "dependency_strength",
    "evidence_chunk_ids",
    "confidence",
    "justification"
  ],
  "properties": {
    "source_task_id": {
      "type": "string",
      "pattern": "^T\\d{2}$"
    },
    "target_task_id": {
      "type": "string",
      "pattern": "^T\\d{2}$"
    },
    "relation_type": {
      "type": "string",
      "enum": [
        "depends_on",
        "enables",
        "informs",
        "constrains",
        "monitors",
        "changes",
        "communicates_with",
        "none"
      ]
    },
    "dependency_strength": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "evidence_chunk_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    }
  }
}
