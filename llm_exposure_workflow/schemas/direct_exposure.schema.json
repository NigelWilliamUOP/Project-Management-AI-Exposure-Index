{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Direct Exposure",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "direct_dimensions",
    "oversight_dimensions",
    "evidence_chunk_ids",
    "confidence",
    "justification"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^T\\d{2}$"
    },
    "direct_dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "information_gathering",
        "synthesis_reporting",
        "planning_orchestration",
        "monitoring_exception_detection",
        "tool_mediated_execution"
      ],
      "properties": {
        "information_gathering": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "synthesis_reporting": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "planning_orchestration": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "monitoring_exception_detection": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "tool_mediated_execution": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        }
      }
    },
    "oversight_dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stakeholder_judgment",
        "negotiation_persuasion",
        "approval_authority",
        "accountability_risk_ownership"
      ],
      "properties": {
        "stakeholder_judgment": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "negotiation_persuasion": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "approval_authority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "accountability_risk_ownership": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        }
      }
    },
    "evidence_chunk_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    }
  }
}
