{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PMI Evidence Chunk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "standard_source",
    "page_start",
    "page_end",
    "summary",
    "domain_tags",
    "artifact_tags",
    "verb_tags",
    "evidence_strength",
    "confidence"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "pattern": "^(program|portfolio|evm|agile_pg|ba_practice|benefits_pg|estimating_pg|scheduling_pg|wbs_pg|requirements_pg|risk_practice|risk_standard)_p\\d{3}(_c\\d{2})?$"
    },
    "standard_source": {
      "type": "string",
      "enum": [
        "program",
        "portfolio",
        "evm",
        "agile_pg",
        "ba_practice",
        "benefits_pg",
        "estimating_pg",
        "scheduling_pg",
        "wbs_pg",
        "requirements_pg",
        "risk_practice",
        "risk_standard"
      ]
    },
    "page_start": {
      "type": "integer",
      "minimum": 1
    },
    "page_end": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "domain_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "strategic_alignment",
          "benefits_management",
          "business_analysis",
          "stakeholder_engagement",
          "governance",
          "collaboration",
          "life_cycle_management",
          "agile_delivery",
          "portfolio_strategic_management",
          "capacity_capability_management",
          "value_management",
          "risk_management",
          "requirements_management",
          "estimating",
          "scheduling_management",
          "work_breakdown_management",
          "scope_schedule_cost_integration",
          "baseline_control",
          "monitoring_control",
          "reporting",
          "change_control",
          "resource_management",
          "communications_management"
        ]
      },
      "uniqueItems": true
    },
    "artifact_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "project_management_plan",
          "program_management_plan",
          "portfolio_management_plan",
          "business_case",
          "charter",
          "roadmap",
          "wbs",
          "wbs_dictionary",
          "obs",
          "ram",
          "budget",
          "estimate",
          "basis_of_estimate",
          "schedule",
          "activity_list",
          "network_diagram",
          "milestone_list",
          "baseline",
          "performance_report",
          "risk_register",
          "communications_plan",
          "change_request",
          "stakeholder_register",
          "requirements_document",
          "backlog",
          "deliverable",
          "benefits_plan",
          "benefits_register"
        ]
      },
      "uniqueItems": true
    },
    "verb_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "evidence_strength": {
      "type": "string",
      "enum": [
        "core",
        "supporting"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
