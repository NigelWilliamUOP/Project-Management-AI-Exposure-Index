{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "onet_task_text",
    "onet_importance",
    "functional_modes",
    "pmi_domain_mappings",
    "likely_inputs",
    "likely_outputs",
    "required_artifacts",
    "likely_upstream_task_ids",
    "likely_downstream_task_ids",
    "evidence_chunk_ids",
    "confidence",
    "justification"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^T\\d{2}$"
    },
    "onet_task_text": {
      "type": "string",
      "minLength": 1
    },
    "onet_importance": {
      "type": "number"
    },
    "functional_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "planning",
          "coordination",
          "monitoring",
          "governance",
          "reporting",
          "resource_management",
          "risk_management",
          "stakeholder_management",
          "change_control",
          "vendor_management",
          "budgeting",
          "quality_management"
        ]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "pmi_domain_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "standard_source",
          "domain",
          "fit_score",
          "chunk_ids"
        ],
        "properties": {
          "standard_source": {
            "type": "string",
            "enum": [
              "program",
              "portfolio",
              "evm",
              "agile_pg",
              "ba_practice",
              "benefits_pg",
              "estimating_pg",
              "scheduling_pg",
              "wbs_pg",
              "requirements_pg",
              "risk_practice",
              "risk_standard"
            ]
          },
          "domain": {
            "type": "string"
          },
          "fit_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "chunk_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    "likely_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "likely_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "likely_upstream_task_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^T\\d{2}$"
      },
      "uniqueItems": true
    },
    "likely_downstream_task_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^T\\d{2}$"
      },
      "uniqueItems": true
    },
    "evidence_chunk_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    }
  }
}
